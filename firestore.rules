rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Primitives
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    // Admin check - allows read on admins table to verify role
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admins Collection
    // Only existing admins can read/write the admins list
    match /admins/{adminId} {
      function isValidAdmin(data) {
        return data.keys().hasAll(['email', 'role', 'createdAt']) 
          && data.keys().size() == 3
          && data.email is string && data.email.size() > 0 && data.email.size() <= 200
          && data.role == 'admin'
          && data.createdAt is number;
      }
      
      allow get: if (isAdmin() || (request.auth.uid == adminId && request.auth.token.email == 'kipiraten@gmail.com')) && isValidId(adminId);
      allow list: if isAdmin();
      
      allow create: if (isAdmin() || request.auth.token.email == 'kipiraten@gmail.com') && isValidId(adminId) && isValidAdmin(incoming());
      allow update: if false; // Admins are immutable, delete and recreate
      allow delete: if isAdmin() && isValidId(adminId);
    }

    // Categories
    match /categories/{categoryId} {
      function isValidCategory(data) {
        let keys = data.keys();
        return keys.hasAll(['title', 'slug', 'description', 'sortOrder', 'createdAt', 'updatedAt'])
          && data.title is string && data.title.size() > 0 && data.title.size() <= 100
          && data.slug is string && data.slug.size() > 0 && data.slug.size() <= 100
          && data.description is string && data.description.size() <= 1000
          && data.sortOrder is number
          && data.createdAt is number
          && data.updatedAt is number
          && (!keys.hasAny(['parentId']) || data.parentId is string || data.parentId == null)
          && (!keys.hasAny(['image']) || data.image is string || data.image == null);
      }

      allow get: if isValidId(categoryId);
      allow list: if true; // Public read

      allow create: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming());
        
      allow update: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming())
        && incoming().createdAt == existing().createdAt;
        
      allow delete: if isAdmin() && isValidId(categoryId);
    }

    // Products
    match /products/{productId} {
      function isValidProduct(data) {
        let keys = data.keys();
        return keys.hasAll(['title', 'description', 'price', 'categoryId', 'images', 'isVisible', 'createdAt', 'updatedAt'])
          && (keys.size() >= 8 && keys.size() <= 15)
          && (!('variants' in keys) || data.variants is list)
          && (!('stock' in keys) || data.stock is number) 
          && (!('subcategoryId' in keys) || data.subcategoryId is string)
          && (!('seoAltText' in keys) || data.seoAltText is string || data.seoAltText == null)
          && (!('seoAltTexts' in keys) || data.seoAltTexts is list)
          && (!('imageNames' in keys) || data.imageNames is list)
          && data.title is string && data.title.size() > 0 && data.title.size() <= 150
          && data.description is string && data.description.size() <= 10000
          && data.price is number && data.price >= 0
          && data.categoryId is string && data.categoryId.size() > 0 && data.categoryId.size() <= 128
          && data.images is list && data.images.size() <= 20
          && (data.images.size() == 0 || data.images[0] is string)
          && data.isVisible is bool
          && data.createdAt is number
          && data.updatedAt is number;
      }

      // Public can read if product is visible, admins can read all
      allow get: if isValidId(productId) && (existing().isVisible == true || isAdmin());
      allow list: if existing().isVisible == true || isAdmin();

      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming())
        && exists(/databases/$(database)/documents/categories/$(incoming().categoryId));
        
      allow update: if isAdmin() && isValidId(productId) && isValidProduct(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasAny(['title', 'description', 'price', 'categoryId', 'subcategoryId', 'images', 'isVisible', 'updatedAt', 'variants', 'stock', 'seoAltText', 'seoAltTexts', 'imageNames']);
        
      allow delete: if isAdmin() && isValidId(productId);
    }

    // Orders
    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.keys().hasAll(['items', 'total', 'status', 'paymentMethod', 'customerEmail', 'customerName', 'shippingAddress', 'createdAt', 'updatedAt'])
          && data.keys().size() == 9
          && data.items is list && data.items.size() > 0 && data.items.size() <= 50
          && data.total is number && data.total > 0
          && data.status is string && data.status in ['pending', 'paid', 'shipped', 'cancelled']
          && data.paymentMethod is string && data.paymentMethod in ['ueberweisung', 'paypal']
          && data.customerEmail is string && data.customerEmail.size() > 0 && data.customerEmail.size() <= 200
          && data.customerName is string && data.customerName.size() > 0 && data.customerName.size() <= 150
          && data.shippingAddress is string && data.shippingAddress.size() > 0 && data.shippingAddress.size() <= 500
          && data.createdAt is number
          && data.updatedAt is number;
      }

      allow get: if isAdmin() && isValidId(orderId);
      allow list: if isAdmin();

      allow create: if isValidId(orderId) && isValidOrder(incoming())
        && incoming().status == 'pending';
        
      allow update: if isAdmin() && isValidId(orderId) && isValidOrder(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);
        
      allow delete: if isAdmin() && isValidId(orderId);
    }
  }
}
