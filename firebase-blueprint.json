{
  "entities": {
    "Admin": {
      "title": "Admin User",
      "description": "Authorized administrators",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin"] },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "sortOrder": { "type": "number" },
        "parentId": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "slug", "sortOrder", "createdAt", "updatedAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A product available in the shop",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "categoryId": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "imageNames": { "type": "array", "items": { "type": "string" }, "description": "SEO-friendly filenames for the images" },
        "stock": { "type": "number" },
        "isVisible": { "type": "boolean" },
        "seoAltText": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "description", "price", "categoryId", "images", "stock", "isVisible", "createdAt", "updatedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "cancelled"] },
        "paymentMethod": { "type": "string", "enum": ["ueberweisung", "paypal"] },
        "customerEmail": { "type": "string" },
        "customerName": { "type": "string" },
        "shippingAddress": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["items", "total", "status", "paymentMethod", "customerEmail", "customerName", "shippingAddress", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/admins/{adminId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Stores admin users"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Shop categories"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Shop products"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders"
    }
  }
}
